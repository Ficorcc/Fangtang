---
import Layout from '../../layouts/Layout.astro';
import { getAllPosts, getSortedPosts, getPostsByTag } from '../../utils/posts';

export async function getStaticPaths() {
  const tagSet = new Set<string>();
  getAllPosts().forEach(post => {
    if (post.data.tags) {
      post.data.tags.forEach(tag => tagSet.add(tag));
    }
  });
  return Array.from(tagSet).map(tag => ({ params: { tag } }));
}

const { tag } = Astro.params;
const filteredPosts = getPostsByTag(tag || '');

function formatDate(dateStr: string): string {
  const date = new Date(dateStr);
  return `${date.getFullYear()}年${date.getMonth() + 1}月${date.getDate()}日`;
}
---

<Layout title={`标签: ${tag}`} description={`包含 ${tag} 标签的所有文章`}>
  <div class="page-container">
    <header class="page-header">
      <h1 class="page-title">🏷️ 标签: {tag}</h1>
      <p class="page-description">共 {filteredPosts.length} 篇相关文章</p>
      <p><a href="/tags" class="back-link">← 返回全部标签</a></p>
    </header>
    
    <div class="posts-list">
      {filteredPosts.map(post => (
        <article class="post-card">
          <h2>
            <a href={`/${post.slug}/`} class="post-link">
              {post.data.title}
            </a>
          </h2>
          <div class="post-meta">
            <span class="meta-item">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                <line x1="16" y1="2" x2="16" y2="6"></line>
                <line x1="8" y1="2" x2="8" y2="6"></line>
                <line x1="3" y1="10" x2="21" y2="10"></line>
              </svg>
              <time datetime={new Date(post.data.date).toISOString()}>{formatDate(post.data.date)}</time>
            </span>
            {post.data.category && (
              <span class="meta-item">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
                </svg>
                <span>{post.data.category}</span>
              </span>
            )}
          </div>
        </article>
      ))}
    </div>
  </div>
</Layout>

<style>
.back-link {
  color: var(--accent);
  text-decoration: none;
  font-size: 14px;
}

.back-link:hover {
  text-decoration: underline;
}
</style>
