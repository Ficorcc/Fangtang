---
import Layout from '../layouts/Layout.astro';
import { getSortedPosts } from '../utils/posts';
import { siteConfig } from '../config';
import Waline from '../components/Waline.astro';

export async function getStaticPaths() {
  const allPosts = getSortedPosts();
  return allPosts.map(post => ({
    params: { slug: post.slug },
    props: { post, allPosts }
  }));
}

const { post, allPosts } = Astro.props;

function formatDate(dateStr: string): string {
  const date = new Date(dateStr);
  return `${date.getFullYear()}年${date.getMonth() + 1}月${date.getDate()}日`;
}

const wordCount = String(post.body || '').replace(/\s/g, '').length;
const readingTime = Math.ceil(wordCount / 300);

// 排序文章按日期降序
const sortedPosts = allPosts.sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
const currentIndex = sortedPosts.findIndex(p => p.slug === post.slug);
const prevPost = currentIndex < sortedPosts.length - 1 ? sortedPosts[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? sortedPosts[currentIndex - 1] : null;
---

<Layout title={post.data.title} description={post.data.excerpt || post.body.slice(0, 160)}>
  <article class="single-post">
    <header class="post-header">
      <h1 class="post-title">{post.data.title}</h1>
      <div class="post-meta">
        <span class="meta-item">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
            <line x1="16" y1="2" x2="16" y2="6"></line>
            <line x1="8" y1="2" x2="8" y2="6"></line>
            <line x1="3" y1="10" x2="21" y2="10"></line>
          </svg>
          <time datetime={new Date(post.data.date).toISOString()}>{formatDate(post.data.date)}</time>
        </span>
        {post.data.category && (
            <span class="meta-item">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
              </svg>
              <a href={post.data.category === '技术' ? '/it' : post.data.category === '生活' ? '/my' : `/categories/${encodeURIComponent(post.data.category)}`} class="category-link">{post.data.category}</a>
            </span>
          )}
        {post.data.tags && post.data.tags.length > 0 && (
            <span class="meta-item tags-inline">
              {post.data.tags.map((tag: string) => (
                <a href={`/tags/${encodeURIComponent(tag)}`} class="post-tag-bordered">#{tag}</a>
              ))}
            </span>
          )}
        <span class="meta-item">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
            <polyline points="14 2 14 8 20 8"></polyline>
            <line x1="16" y1="13" x2="8" y2="13"></line>
            <line x1="16" y1="17" x2="8" y2="17"></line>
            <polyline points="10 9 9 9 8 9"></polyline>
          </svg>
          <span>{wordCount} 字</span>
        </span>
        <span class="meta-item">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"></circle>
            <polyline points="12 6 12 12 16 14"></polyline>
          </svg>
          <span>约 {readingTime} 分钟</span>
        </span>
      </div>
    </header>
    <div class="post-content">
      <Fragment set:html={post.html} />
    </div>

    <!-- 作者信息和版权声明 -->
    <div class="post-author-copyright">
      <div class="author-info">
        <p><strong>文章作者：</strong> Ficor</p>
        <p><strong>本文链接：</strong> <a href={`${siteConfig.url}/${post.slug}/`} target="_blank">${siteConfig.url}/${post.slug}/</a></p>
        <p><strong>版权声明：</strong> 采用 CC BY-NC-SA 4.0 许可协议，转载请注明出处。</p>
      </div>
    </div>

    <!-- 上下篇导航 -->
    <div class="post-navigation">
      <div class="nav-container left">
        {prevPost && (
          <a href={`/${prevPost.slug}/`} class="nav-prev">
            <span class="nav-arrow">←</span>
            <span class="nav-text">上一篇</span>
            <span class="nav-title">{prevPost.data.title}</span>
          </a>
        )}
      </div>
      <div class="nav-container right">
        {nextPost && (
          <a href={`/${nextPost.slug}/`} class="nav-next">
            <span class="nav-text">下一篇</span>
            <span class="nav-title">{nextPost.data.title}</span>
            <span class="nav-arrow">→</span>
          </a>
        )}
      </div>
    </div>

    <!-- Waline 评论区 -->
    <div id="comments-section" class="post-comments">
      <h3>评论</h3>
      <Waline />
    </div>
  </article>



  <!-- Post Scroll Buttons -->
  <div class="post-scroll-buttons">
    <button
      id="post-back-to-top"
      class="post-scroll-btn"
      aria-label="返回顶部"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <polyline points="18 15 12 9 6 15"></polyline>
      </svg>
    </button>
    <button
      id="post-go-to-comments"
      class="post-scroll-btn"
      aria-label="跳转到评论"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
      </svg>
    </button>
  </div>

  <script>
    const globalButtons = document.querySelector('body > .scroll-buttons');
    if (globalButtons) {
      globalButtons.remove();
    }
    
    const backTop = document.getElementById('post-back-to-top') as HTMLElement;
    const goComments = document.getElementById('post-go-to-comments') as HTMLElement;
    const scrollButtons = document.querySelector('.post-scroll-buttons') as HTMLElement;
    const footer = document.querySelector('.site-footer') as HTMLElement;
    const commentsSection = document.getElementById('comments-section');
    
    if (backTop && goComments && scrollButtons && footer) {
      backTop.style.display = 'flex';
      goComments.style.display = 'flex';
      
      const updateButtonsPosition = () => {
        const footerRect = footer.getBoundingClientRect();
        const windowHeight = window.innerHeight;
        const baseOffset = window.innerWidth <= 768 ? 16 : 24;
        
        if (footerRect.top < windowHeight) {
          const overlap = windowHeight - footerRect.top + baseOffset;
          scrollButtons.style.bottom = `${overlap}px`;
        } else {
          scrollButtons.style.bottom = `${baseOffset}px`;
        }
      };
      
      window.addEventListener('scroll', updateButtonsPosition);
      window.addEventListener('resize', updateButtonsPosition);
      updateButtonsPosition();
      
      backTop.addEventListener('click', () => {
        window.scrollTo({ top: 0, behavior: 'smooth' });
      });
      
      goComments.addEventListener('click', () => {
        commentsSection?.scrollIntoView({ behavior: 'smooth' });
      });
    }
  </script>
</Layout>

<style>
  .single-post {
    max-width: 800px;
    margin: 0 auto;
    padding: 40px 20px;
  }

  .post-header {
    margin-bottom: 25px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--border);
  }

  .post-title {
    font-size: 2rem;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 20px;
    line-height: 1.3;
  }

  .post-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    margin-bottom: 20px;
  }

  .meta-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.9rem;
    color: var(--text-secondary);
  }

  .meta-item svg {
    width: 16px;
    height: 16px;
  }

  .tags-inline {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .post-tag-bordered {
    padding: 3px 8px;
    border: 1px solid var(--border);
    border-radius: 4px;
    font-size: 0.8rem;
    color: var(--accent);
    background: transparent;
    transition: all 0.2s;
  }

  .post-tag-bordered:hover {
    border-color: var(--accent);
    background: rgba(108, 187, 247, 0.1);
  }

  .post-content {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--text);
  }

  .post-content :global(h2) {
    font-size: 1.5rem;
    margin: 40px 0 20px;
    padding-bottom: 10px;
    border-bottom: 2px solid var(--border);
  }

  .post-content :global(h3) {
    font-size: 1.25rem;
    margin: 30px 0 15px;
  }

  .post-content :global(p) {
    margin-bottom: 20px;
  }

  .post-content :global(ul),
  .post-content :global(ol) {
    margin: 20px 0;
    padding-left: 25px;
  }

  .post-content :global(li) {
    margin-bottom: 10px;
  }

  .post-content :global(a) {
    color: var(--accent);
    text-decoration: underline;
  }

  .post-content :global(code) {
    padding: 2px 6px;
    background: var(--bg-secondary);
    border-radius: 4px;
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.9em;
  }

  .post-content :global(pre) {
    margin: 20px 0;
    padding: 20px;
    background: var(--bg-secondary);
    border-radius: 8px;
    overflow-x: auto;
  }

  .post-content :global(pre code) {
    background: transparent;
    padding: 0;
  }

  .post-content :global(blockquote) {
    margin: 20px 0;
    padding: 15px 20px;
    border-left: 4px solid var(--accent);
    background: var(--bg-secondary);
    border-radius: 0 8px 8px 0;
    font-style: italic;
  }

  /* 作者信息和版权声明 */
  .post-author-copyright {
    margin: 40px 0;
    padding: 20px;
    background: var(--bg-secondary);
    border-left: 4px solid var(--accent);
    border-radius: 0 8px 8px 0;
  }

  .author-info p {
    margin-bottom: 10px;
    font-size: 0.95rem;
    line-height: 1.5;
  }

  .author-info a {
    color: var(--accent);
    text-decoration: underline;
  }

  /* 上下篇导航 */
  .post-navigation {
    margin: 40px 0;
    display: flex;
    justify-content: space-between;
    gap: 20px;
  }

  .nav-container {
    flex: 1;
  }

  .nav-container.left {
    text-align: left;
  }

  .nav-container.right {
    text-align: right;
  }

  .nav-prev, .nav-next {
    display: inline-block;
    width: 100%;
    padding: 15px;
    border: 1px solid var(--border);
    border-radius: 8px;
    text-decoration: none;
    color: var(--text);
    transition: all 0.2s;
    display: flex;
    align-items: center;
  }

  .nav-prev:hover, .nav-next:hover {
    border-color: var(--accent);
    background: rgba(108, 187, 247, 0.1);
  }

  .nav-prev {
    justify-content: flex-start;
  }

  .nav-next {
    justify-content: flex-end;
  }

  .nav-arrow {
    font-size: 1.2rem;
    margin: 0 10px;
  }

  .nav-text {
    font-size: 0.9rem;
    color: var(--text-secondary);
  }

  .nav-title {
    margin: 0 10px;
    font-weight: 500;
  }

  /* 评论表单 */
  .post-comments {
    margin: 40px 0;
  }

  .post-comments h3 {
    font-size: 1.25rem;
    margin-bottom: 20px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--border);
  }

  .comment-form {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .form-row {
    display: flex;
    gap: 15px;
  }

  .form-group {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .form-group label {
    font-size: 0.9rem;
    color: var(--text-secondary);
  }

  .form-group input,
  .form-group textarea {
    padding: 10px;
    border: 1px solid var(--border);
    border-radius: 4px;
    font-size: 1rem;
    background: var(--bg);
    color: var(--text);
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 2px rgba(108, 187, 247, 0.2);
  }

  .form-group textarea {
    resize: vertical;
    min-height: 120px;
  }

  .form-actions {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .comment-tools {
    display: flex;
    gap: 10px;
  }

  .tool-btn {
    padding: 8px;
    border: 1px solid var(--border);
    border-radius: 4px;
    background: var(--bg);
    color: var(--text);
    cursor: pointer;
    transition: all 0.2s;
  }

  .tool-btn:hover {
    border-color: var(--accent);
    background: rgba(108, 187, 247, 0.1);
  }

  .submit-btn {
    padding: 10px 24px;
    border: none;
    border-radius: 4px;
    background: var(--accent);
    color: white;
    font-size: 1rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.2s;
  }

  .submit-btn:hover {
    background: var(--accent-dark);
  }



  /* Post Scroll Buttons */
  .post-scroll-buttons {
    position: fixed;
    bottom: 24px;
    right: 24px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    z-index: 50;
  }

  .post-scroll-btn {
    width: 40px;
    height: 40px;
    background: var(--back-top-bg);
    border: 1px solid var(--border);
    border-radius: 10px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--shadow);
    color: var(--text-secondary);
    transition: all 0.2s;
  }

  .post-scroll-btn:hover {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
  }

  @media (max-width: 768px) {
    .post-title {
      font-size: 1.5rem;
    }
    
    .single-post {
      padding: 20px 15px;
    }

    .form-row {
      flex-direction: column;
    }

    .post-navigation {
      flex-direction: column;
    }

    .nav-prev, .nav-next {
      justify-content: center;
    }

    .post-scroll-buttons {
      bottom: 16px;
      right: 16px;
      gap: 6px;
    }

    .post-scroll-btn {
      width: 36px;
      height: 36px;
    }
  }

  /* Waline 主题适配 - 不改变原有评论区容器样式 */
  :global(:root) {
    --waline-theme-color: var(--accent);
    --waline-active-color: var(--accent-hover);
    --waline-bgcolor: var(--bg);
    --waline-bgcolor-light: var(--bg-card);
    --waline-border-color: var(--border);
    --waline-text-color: var(--text);
    --waline-font-size: 1rem;
  }

  :global(html[data-theme='dark']),
  :global(:root.dark) {
    --waline-bgcolor: var(--bg);
    --waline-bgcolor-light: var(--bg-card);
    --waline-border-color: var(--border);
  }

  :global(#waline) {
    --waline-theme-color: var(--accent);
    --waline-active-color: var(--accent-hover);
    --waline-bgcolor: var(--bg);
    --waline-bgcolor-light: var(--bg-card);
    --waline-border-color: var(--border);
    --waline-text-color: var(--text);
  }
</style>
