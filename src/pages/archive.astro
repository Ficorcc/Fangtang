---
import Layout from '../layouts/Layout.astro';
import { getSortedPosts } from '../utils/posts';

const allPosts = getSortedPosts();

const archiveMap = new Map<string, typeof allPosts>();
allPosts.forEach(post => {
  const date = new Date(post.data.date);
  const key = `${date.getFullYear()}年${date.getMonth() + 1}月`;
  if (!archiveMap.has(key)) {
    archiveMap.set(key, []);
  }
  archiveMap.get(key)!.push(post);
});

const archives = Array.from(archiveMap.entries());
---

<Layout title="归档" description="文章时间归档">
  <div class="page-container">
    <header class="page-header">
      <h1 class="page-title">📦 归档</h1>
      <p class="page-description">共 {allPosts.length} 篇文章，{archives.length} 个月</p>
    </header>
    
    <div class="archive-list">
      {archives.map(([month, posts]) => (
        <div class="archive-item">
          <h3 class="archive-month">{month}</h3>
          <ul class="archive-posts">
            {posts.map(post => (
              <li>
                <span class="archive-date">{new Date(post.data.date).getDate()}日</span>
                <a href={post.slug + '/'}>{post.data.title}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</Layout>
