---
import Layout from '../layouts/Layout.astro';
---

<Layout title="关于" description="关于这个博客和博主">
  <div class="page-container">
    <header class="page-header">
      <h1 class="page-title">👋 关于</h1>
      <p class="page-description">关于这个博客和我</p>
    </header>
    
    <div class="post-card" style="margin-bottom: 24px;">
      <h2>🙋‍♂️ 关于我</h2>
      <p>你好！我是菲克，一名热爱技术的开发者。</p>
      <p>这里是我的个人博客，记录生活与技术的点滴。</p>
    </div>
    
    <div class="post-card" style="margin-bottom: 24px;">
      <h2>🔧 技术栈</h2>
      <ul style="padding-left: 20px; line-height: 2;">
        <li><strong>前端</strong>：Astro, React, Vue, TypeScript, Tailwind CSS</li>
        <li><strong>后端</strong>：Node.js, Go, Python</li>
        <li><strong>运维</strong>：Docker, Linux, Nginx</li>
        <li><strong>数据库</strong>：MySQL, PostgreSQL, Redis</li>
      </ul>
    </div>
    
    <div class="post-card" style="margin-bottom: 24px;">
      <h2>📡 本站信息</h2>
      <ul style="padding-left: 20px; line-height: 2;">
        <li><strong>框架</strong>：Astro 5.x</li>
        <li><strong>主题</strong>：Sugar 主题（自研）</li>
        <li><strong>部署</strong>：HostDZire + 又拍云 CDN</li>
      </ul>
    </div>
    
    <div class="post-card">
      <h2>📫 联系方式</h2>
      <ul style="padding-left: 20px; line-height: 2;">
        <li><strong>邮箱</strong>：<a href="mailto:ficor@ficor.cc">ficor@ficor.cc</a></li>
        <li><strong>博客</strong>：<a href="https://blog.ficor.cc" target="_blank">https://blog.ficor.cc</a></li>
        <li><strong>GitHub</strong>：<a href="https://github.com/ficorcc" target="_blank">@ficorcc</a></li>
      </ul>
    </div>
  </div>
</Layout>
